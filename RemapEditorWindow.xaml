<Window x:Class="KeyNexus.RemapEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editor de Mapeamento" Height="540" Width="660"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDarkBrush}"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock x:Name="txtDeviceName" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Regras exclusivas para este teclado"
                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            <TextBlock x:Name="txtLayoutHint" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" CornerRadius="12" Padding="16" Margin="0,0,0,14"
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,10">
                    <TextBlock Text="GATILHO" Style="{StaticResource SectionLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="cmbTriggerKey" Style="{StaticResource ModernComboBox}"
                                  IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="CmbTriggerKey_SelectionChanged"
                                  ToolTip="Selecione ou digite para filtrar"/>
                        <Button x:Name="btnCaptureKey" Grid.Column="1" Content="⌨"
                                Style="{StaticResource IconButton}" Click="BtnCaptureKey_Click"
                                Margin="8,0,0,0" ToolTip="Capturar tecla"/>
                    </Grid>
                    <WrapPanel Margin="0,8,0,0">
                        <CheckBox x:Name="chkModCtrl" Content="Ctrl" Style="{StaticResource ModernCheckBox}"
                                  FontSize="11" Margin="0,0,12,0" Click="TriggerModifier_Click"/>
                        <CheckBox x:Name="chkModShift" Content="Shift" Style="{StaticResource ModernCheckBox}"
                                  FontSize="11" Margin="0,0,12,0" Click="TriggerModifier_Click"/>
                        <CheckBox x:Name="chkModAlt" Content="Alt" Style="{StaticResource ModernCheckBox}"
                                  FontSize="11" Click="TriggerModifier_Click"/>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,10">
                    <TextBlock Text="TIPO DE SAÍDA" Style="{StaticResource SectionLabel}"/>
                    <ComboBox x:Name="cmbOutputType" Style="{StaticResource ModernComboBox}"
                              SelectionChanged="CmbOutputType_SelectionChanged">
                        <ComboBoxItem Content="Tecla" Tag="Key" IsSelected="True"/>
                        <ComboBoxItem Content="Texto" Tag="Text"/>
                        <ComboBoxItem Content="Sequência / Macro" Tag="Sequence"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel x:Name="panelOutputKey" Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                    <TextBlock Text="SAÍDA" Style="{StaticResource SectionLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="cmbOutputKey" Style="{StaticResource ModernComboBox}"
                                  IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="CmbOutputKey_SelectionChanged"/>
                        <Button x:Name="btnCaptureOutputKey" Grid.Column="1" Content="⌨"
                                Style="{StaticResource IconButton}" Click="BtnCaptureOutputKey_Click"
                                Margin="8,0,0,0" ToolTip="Capturar tecla"/>
                    </Grid>
                </StackPanel>

                <StackPanel x:Name="panelOutputText" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                            Margin="0,0,0,8" Visibility="Collapsed">
                    <TextBlock Text="TEXTO" Style="{StaticResource SectionLabel}"/>
                    <TextBox x:Name="txtOutputText" Style="{StaticResource AliasTextBox}"/>
                </StackPanel>

                <StackPanel x:Name="panelOutputSequence" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                            Margin="0,0,0,8" Visibility="Collapsed">
                    <TextBlock Text="SEQUÊNCIA" Style="{StaticResource SectionLabel}"/>
                    <TextBox x:Name="txtOutputSequence" Style="{StaticResource AliasTextBox}"
                             ToolTip="Ex: F1,100; F2,50; A,0"/>
                </StackPanel>

                <Button Grid.Row="2" Grid.Column="1" Content="Adicionar regra"
                        Style="{StaticResource ModernButton}" HorizontalAlignment="Right"
                        Click="BtnAddRule_Click" Margin="0,6,0,0" FontSize="12"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" CornerRadius="12" Padding="8"
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
            <ListView x:Name="lstRules" Background="Transparent" BorderThickness="0"
                      Foreground="{StaticResource TextPrimaryBrush}" FontSize="12.5">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Gatilho" Width="150" DisplayMemberBinding="{Binding TriggerDisplay}"/>
                        <GridViewColumn Header="Saída" Width="210" DisplayMemberBinding="{Binding OutputDisplay}"/>
                        <GridViewColumn Header="Tipo" Width="90" DisplayMemberBinding="{Binding TypeDisplay}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <TextBlock Grid.Row="3" x:Name="txtRuleCount" FontSize="11"
                   Foreground="{StaticResource TextMutedBrush}" Margin="0,10,0,0"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Remover selecionada" Style="{StaticResource SecondaryButton}"
                    Click="BtnRemoveRule_Click" Margin="0,0,8,0"/>
            <Button Content="Salvar e fechar" Style="{StaticResource ModernButton}"
                    Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>

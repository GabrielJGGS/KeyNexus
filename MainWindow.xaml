<Window x:Class="KeyNexus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeyNexus" Height="580" Width="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock FontSize="28" FontWeight="Bold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource Accent}" Offset="0"/>
                            <GradientStop Color="{StaticResource AccentLight}" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                    <Run Text="⌨"/>
                    <Run Text=" Key"/>
                    <Run Text="Nexus" FontWeight="Light"/>
                </TextBlock>
                <TextBlock Text="Vincule layouts de idioma a cada teclado físico conectado." 
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="1" CornerRadius="10" Padding="16,10" Margin="0,0,0,14"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#2A2A3D" Offset="0"/>
                    <GradientStop Color="#302848" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="10" Height="10" CornerRadius="5" Background="{StaticResource SuccessBrush}" 
                        VerticalAlignment="Center" Margin="0,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect Color="{StaticResource Success}" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                    </Border.Effect>
                </Border>
                <TextBlock x:Name="txtStatus" Grid.Column="1" FontSize="12.5" TextWrapping="Wrap"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Text="Monitorando teclados..."/>
            </Grid>
        </Border>

        <!-- ═══ LISTA DE TECLADOS ═══ -->
        <Border Grid.Row="2" CornerRadius="10" Padding="4" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Background="{StaticResource BgCardBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="lstKeyboards">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="Transparent" CornerRadius="8" Padding="14,10" Margin="4,3"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Nome + Apelido do Teclado -->
                                    <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal"
                                                Margin="0,0,0,6">
                                        <TextBlock Text="🖮 " FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13.5" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text=" — " Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding Alias, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 FontSize="12" FontStyle="Italic" Width="140"
                                                 Foreground="{StaticResource AccentLightBrush}" 
                                                 Background="Transparent" BorderThickness="0,0,0,1"
                                                 BorderBrush="{StaticResource BorderBrush}"
                                                 ToolTip="Clique para dar um apelido"
                                                 LostFocus="AliasTextBox_LostFocus"/>
                                    </StackPanel>

                                    <!-- Layout ComboBox -->
                                    <ComboBox Grid.Row="1" Grid.Column="0"
                                              ItemsSource="{Binding AvailableLayouts}" 
                                              DisplayMemberPath="Name" SelectedValuePath="Hkl" 
                                              SelectedValue="{Binding SelectedLayoutHkl, Mode=TwoWay}"
                                              SelectionChanged="LayoutComboBox_SelectionChanged"
                                              FontSize="12" Margin="0,0,8,0"/>

                                    <!-- Shortcut ID -->
                                    <TextBlock Grid.Row="1" Grid.Column="1" 
                                               Text="{Binding ShortId}" FontSize="10" 
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Opacity="0.6"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ═══ PREVIEW ═══ -->
        <Border Grid.Row="3" CornerRadius="10" Padding="14,10" Margin="0,14,0,0"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#2A2A3D" Offset="0"/>
                    <GradientStop Color="#282040" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🔍" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Preview em tempo real" FontWeight="SemiBold" FontSize="12"
                               Foreground="{StaticResource AccentLightBrush}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtPreviewDevice" FontSize="12" TextWrapping="Wrap"
                               Foreground="{StaticResource TextPrimaryBrush}" Text="Dispositivo: —"/>
                    <TextBlock x:Name="txtPreviewLayout" FontSize="11.5" Margin="0,2,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" Text="Layout alvo: —"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ OPÇÕES ═══ -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,14,0,0">
            <CheckBox x:Name="chkAutoStart" Style="{StaticResource ModernCheckBox}"
                      Content="  Iniciar com o Windows" Click="ChkAutoStart_Click"/>
        </StackPanel>

        <!-- ═══ RODAPÉ ═══ -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="↻  Atualizar" Style="{StaticResource SecondaryButton}" 
                    Click="BtnRefresh_Click" Margin="0,0,8,0"/>
            <Button Content="Fechar" Style="{StaticResource SecondaryButton}" 
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>

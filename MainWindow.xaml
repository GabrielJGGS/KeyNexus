<Window x:Class="KeyNexus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeyNexus" Height="520" Width="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="⌨ KeyNexus" FontSize="22" FontWeight="Bold" 
                       Foreground="{StaticResource AccentLightBrush}"/>
            <TextBlock Text="Vincule um layout de idioma a cada teclado físico conectado." 
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ═══ BARRA DE STATUS ═══ -->
        <Border Grid.Row="1" Background="{StaticResource BgCardBrush}" CornerRadius="8" 
                Padding="14,10" Margin="0,0,0,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="statusDot" Width="10" Height="10" Fill="{StaticResource SuccessBrush}" 
                         VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="txtStatus" Grid.Column="1" FontSize="12" TextWrapping="Wrap"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Text="Aguardando atividade do teclado..."/>
            </Grid>
        </Border>

        <!-- ═══ LISTA DE TECLADOS ═══ -->
        <Border Grid.Row="2" Background="{StaticResource BgCardBrush}" CornerRadius="8" 
                Padding="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <ListView x:Name="lstKeyboards" Background="Transparent" BorderThickness="0"
                      Foreground="{StaticResource TextPrimaryBrush}" FontSize="13">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="Margin" Value="0,1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6" 
                                            Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <GridViewColumn Header="Teclado" Width="260" DisplayMemberBinding="{Binding DisplayName}"/>
                        <GridViewColumn Header="Layout de Idioma" Width="370">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox Width="340" 
                                          ItemsSource="{Binding AvailableLayouts}" 
                                          DisplayMemberPath="Name" SelectedValuePath="Hkl" 
                                          SelectedValue="{Binding SelectedLayoutHkl, Mode=TwoWay}"
                                          SelectionChanged="LayoutComboBox_SelectionChanged"
                                          FontSize="12"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- ═══ PREVIEW EM TEMPO REAL ═══ -->
        <Border Grid.Row="3" Background="{StaticResource BgCardBrush}" CornerRadius="8" 
                Padding="14,10" Margin="0,12,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="🔍 Preview em tempo real" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource AccentLightBrush}" Margin="0,0,0,6"/>
                <TextBlock x:Name="txtPreviewDevice" FontSize="12" TextWrapping="Wrap"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Text="Dispositivo: —"/>
                <TextBlock x:Name="txtPreviewLayout" FontSize="12" Margin="0,3,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Layout alvo: —"/>
            </StackPanel>
        </Border>

        <!-- ═══ OPÇÕES ═══ -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,0">
            <CheckBox x:Name="chkAutoStart" Style="{StaticResource ModernCheckBox}"
                      Content="Iniciar com o Windows" Click="ChkAutoStart_Click"/>
        </StackPanel>

        <!-- ═══ RODAPÉ COM BOTÕES ═══ -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="↻ Atualizar Lista" Style="{StaticResource SecondaryButton}" 
                    Click="BtnRefresh_Click" Margin="0,0,8,0"/>
            <Button Content="Fechar" Style="{StaticResource SecondaryButton}" 
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>

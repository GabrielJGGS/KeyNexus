<Window x:Class="KeyNexus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeyNexus" Height="680" Width="820"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}"
        ResizeMode="CanResizeWithGrip"
        MinHeight="520" MinWidth="640">

    <Grid>
        <!-- Fundo com gradiente sutil -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#13111C" Offset="0"/>
                <GradientStop Color="#1A1528" Offset="0.55"/>
                <GradientStop Color="#13111C" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Glow decorativo -->
        <Ellipse Width="420" Height="420" HorizontalAlignment="Right" VerticalAlignment="Top"
                 Margin="0,-180,-120,0" IsHitTestVisible="False" Opacity="0.12">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#8B5CF6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid Margin="28,24,28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="48" Height="48" CornerRadius="12"
                        BorderBrush="#558B5CF6" BorderThickness="1" Margin="0,0,16,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3D2D6B" Offset="0"/>
                            <GradientStop Color="#2A2538" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="⌨" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                        <Run Text="Key"/>
                        <Run Text="Nexus" Foreground="{StaticResource AccentLightBrush}" FontWeight="Light"/>
                    </TextBlock>
                    <TextBlock Text="Layouts e mapeamentos por teclado físico"
                               FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                </StackPanel>

                <Border Grid.Column="2" CornerRadius="20" Padding="12,5"
                        Background="{StaticResource BgElevatedBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        VerticalAlignment="Top">
                    <TextBlock x:Name="txtVersion" FontSize="11" FontWeight="Medium"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </Border>
            </Grid>

            <!-- Status bar -->
            <Border Grid.Row="1" CornerRadius="10" Padding="14,11" Margin="0,0,0,16"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Width="10" Height="10" Margin="0,0,12,0" VerticalAlignment="Center">
                        <Ellipse Fill="{StaticResource SuccessBrush}">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="{StaticResource Success}" BlurRadius="10" ShadowDepth="0" Opacity="0.7"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>
                    <TextBlock x:Name="txtStatus" Grid.Column="1" FontSize="12.5" TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Monitorando teclados conectados..."/>
                </Grid>
            </Border>

            <!-- Cards -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                <ItemsControl x:Name="lstKeyboards">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="14" Margin="0,0,0,14" Padding="0"
                                    Background="{StaticResource BgCardBrush}"
                                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Card header -->
                                    <Border Grid.Row="0" Padding="20,16,20,14"
                                            Background="{StaticResource BgElevatedBrush}"
                                            CornerRadius="14,14,0,0"
                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontSize="16" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                    <TextBlock Text="Apelido" FontSize="10" FontWeight="Bold"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBox Text="{Binding Alias, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                             Style="{StaticResource AliasTextBox}" Width="200"
                                                             ToolTip="Nome personalizado para este teclado"
                                                             LostFocus="AliasTextBox_LostFocus"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                                <Border Style="{StaticResource ChipBadge}" Margin="0,0,8,0"
                                                        Visibility="{Binding HasMultipleCollections, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentLightBrush}">
                                                        <Run Text="{Binding CollectionCount, Mode=OneWay}"/>
                                                        <Run Text=" HID"/>
                                                    </TextBlock>
                                                </Border>
                                                <Button Content="?" Style="{StaticResource IconButton}"
                                                        Click="BtnDeviceInfo_Click" Tag="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Card body -->
                                    <Grid Grid.Row="1" Margin="20,16,20,18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Layout -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="LAYOUT" Style="{StaticResource SectionLabel}"/>
                                            <ComboBox Style="{StaticResource ModernComboBox}"
                                                      ItemsSource="{Binding AvailableLayouts}"
                                                      DisplayMemberPath="Name" SelectedValuePath="Hkl"
                                                      SelectedValue="{Binding SelectedLayoutHkl, Mode=TwoWay}"
                                                      SelectionChanged="LayoutComboBox_SelectionChanged"/>
                                        </StackPanel>

                                        <!-- Remap -->
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="MAPEAMENTO" Style="{StaticResource SectionLabel}"/>
                                            <Border CornerRadius="10" Padding="12,10" Margin="0,0,0,10"
                                                    Background="{StaticResource BgInputBrush}"
                                                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding RemapSummary, Mode=OneWay}" FontSize="12.5"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding ShortId}" FontSize="10" Margin="0,6,0,0"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               ToolTip="{Binding GroupKey}"/>
                                                </StackPanel>
                                            </Border>
                                            <Button Content="Editar mapeamento" HorizontalAlignment="Stretch"
                                                    Style="{StaticResource ModernButton}" FontSize="12"
                                                    Padding="12,8" Click="BtnRemap_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Preview + footer -->
            <Border Grid.Row="3" CornerRadius="12" Margin="0,16,0,0" Padding="16,14"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="TECLADO ATIVO" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="txtPreviewDevice" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Text="—"/>
                        <TextBlock x:Name="txtPreviewLayout" FontSize="12" Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}" Text="Nenhum layout vinculado"/>
                    </StackPanel>

                    <Border Grid.Column="1" Width="1" Margin="20,4" Background="{StaticResource BorderBrush}" Opacity="0.5"/>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center" MinWidth="160">
                        <CheckBox x:Name="chkAutoStart" Style="{StaticResource ModernCheckBox}"
                                  Content="Iniciar com o Windows" Click="ChkAutoStart_Click"/>
                        <TextBlock x:Name="txtUpdateStatus" FontSize="11" Margin="0,8,0,0"
                                   Foreground="{StaticResource WarningBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Actions -->
            <Border Grid.Row="4" Margin="0,14,0,0" Padding="0,14,0,0"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock Text="KeyNexus" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" Opacity="0.6"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnCheckUpdate" Content="Verificar atualizações"
                                Style="{StaticResource SecondaryButton}" Click="BtnCheckUpdate_Click" Margin="0,0,8,0"/>
                        <Button Content="Atualizar lista" Style="{StaticResource SecondaryButton}"
                                Click="BtnRefresh_Click" Margin="0,0,8,0"/>
                        <Button Content="Fechar" Style="{StaticResource SecondaryButton}"
                                Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
